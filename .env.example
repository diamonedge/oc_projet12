POSTGRES_HOST=127.0.0.1
POSTGRES_HOST_PORT=5433

POSTGRES_DB=sport_benefits

POSTGRES_USER=sport_benefits_owner
POSTGRES_PASSWORD=change_me

POSTGRES_APP_USER=sport_benefits_app
POSTGRES_APP_PASSWORD=change_me

# Simulation déterministe des activités sportives
SIMULATION_SEED=20260620
SIMULATION_REFERENCE_DATETIME=2026-06-20T12:00:00

# dbt : transformations SQL et tests
POSTGRES_DBT_USER=sport_benefits_dbt
POSTGRES_DBT_PASSWORD=change_me

# Google Routes
GOOGLE_MAPS_API_KEY=change_me

# Apache Superset : interface web
SUPERSET_HOST_PORT=8088
SUPERSET_SECRET_KEY=change_me

# Apache Superset : compte administrateur
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=Sport
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.local
SUPERSET_ADMIN_PASSWORD=change_me

# Apache Superset : base de métadonnées
SUPERSET_METADATA_DB=superset_meta
SUPERSET_METADATA_USER=superset_meta
SUPERSET_METADATA_PASSWORD=change_me

# Apache Superset : accès en lecture aux données de restitution
SUPERSET_READER_USER=superset_reader
SUPERSET_READER_PASSWORD=change_me

#Pg Admin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=changeme

# slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=...
